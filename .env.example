# Copy this file to .env.local for local overrides.
# Do not commit real API keys, OAuth tokens, wallet secrets, passwords, seed phrases, or private keys.

# Shared local app mode.
APP_ENV=development
APP_NAME=Win11 C2 Dashboard Backend
APP_VERSION=0.1.0

# Local backend run target.
# These values are used by local run scripts/docs; uvicorn still receives host and port as CLI args today.
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8765

# Backend storage and browser access.
# CORS_ALLOWED_ORIGINS is a comma-separated list.
DATABASE_PATH=./data/dashboard.sqlite3
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Renderer API endpoints. Vite only exposes variables prefixed with VITE_.
VITE_BACKEND_HEALTH_URL=http://127.0.0.1:8765/health
VITE_BACKEND_NOTES_URL=http://127.0.0.1:8765/notes
VITE_BACKEND_SETTINGS_URL=http://127.0.0.1:8765/settings
VITE_BACKEND_AUDIT_LOG_URL=http://127.0.0.1:8765/audit-log

# Future integrations: leave blank until each connector is implemented.
# OPENAI_API_KEY=
# WEATHER_API_KEY=
# COINGECKO_API_KEY=
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
